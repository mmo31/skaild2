# Database connection URL for PostgreSQL
# Used by both gateway and control-plane services
SKAILD2_DB_URL=postgres://skaild2:skaild2@postgres:5432/skaild2

# Rust log level (info, debug, warn, error)
RUST_LOG=info

# Control-plane internal API URL (used by gateway)
SKAILD2_CONTROL_PLANE_URL=http://control-plane:8080
